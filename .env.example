USE_MOCK=false
DAYS_AHEAD=30

GOOGLE_CREDENTIALS_FILE=credentials.json
SPREADSHEET_ID=
SHEET_NAME=Events
SHEET_URL=

# Telegram bot token is stored server-side in .env only (never in UI or shared files).
# Chat ID is entered via the web UI and stored securely in private/telegram_settings.json.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CONFIG_PATH=private/telegram_settings.json

# Shared-hosting web runner settings.
# No daemon, queue, worker, Node server, or polling bot is required.
PYTHON_BIN=python3
SCAN_TIMEOUT_SECONDS=180
